{
  "name": "express-text",
  "private": true,
  "version": "0.1.3",
  "description": "Real-time speech transcription and translation desktop app",
  "author": {
    "name": "Hamza Shafique",
    "email": "hamzashafiquehere@gmail.com"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "lint": "oxlint src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@soniox/speech-to-text-web": "^1.4.0",
    "electron-store": "^11.0.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-solid": "^2.11.12"
  },
  "build": {
    "appId": "com.express247.text",
    "productName": "ExpressText",
    "files": [
      "out/**/*",
      "config/**/*"
    ],
    "mac": {
      "target": "dmg",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "ExpressText needs microphone access for real-time speech transcription."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["deb", "AppImage"]
    }
  }
}
