{
  "name": "express-text",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "version": "0.1.26",
  "description": "Real-time speech transcription and translation desktop app",
  "author": {
    "name": "Hamza Shafique",
    "email": "hamzashafiquehere@gmail.com"
  },
  "homepage": "https://github.com/hamza-56",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "lint": "oxlint src/",
    "typecheck": "tsc --build",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@soniox/client": "^2.0.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-solid": "^1.14.0",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12"
  },
  "build": {
    "appId": "com.express247.text",
    "productName": "ExpressText",
    "asar": true,
    "compression": "maximum",
    "files": [
      "out/**/*",
      "config/**/*",
      "build/*.png",
      "!**/*.map",
      "!**/*.d.ts",
      "!**/README*",
      "!**/CHANGELOG*",
      "!**/LICENSE*",
      "!**/__tests__/**",
      "!**/*.spec.*",
      "!**/*.test.*"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": "dmg",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "ExpressText needs microphone access for real-time speech transcription."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "hamza-56",
      "repo": "express-text",
      "private": true,
      "releaseType": "release",
      "vPrefixedTagName": true
    }
  }
}
